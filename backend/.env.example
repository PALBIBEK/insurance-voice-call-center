# Copy to .env - all settings use the IVCC_ prefix. Empty keys = offline demo mode.

# Inference (OpenRouter). Empty -> rule-based demo brain, zero network calls.
IVCC_OPENROUTER_API_KEY=
IVCC_OPENROUTER_MODEL_TRIAGE=openai/gpt-4o-mini
IVCC_OPENROUTER_MODEL_SPECIALIST=openai/gpt-4o

# Voice (ElevenLabs custom-LLM webhook). Empty -> text mode only.
IVCC_ELEVENLABS_API_KEY=
IVCC_ELEVENLABS_AGENT_ID=
IVCC_ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb  # free-tier premade voice (George)
IVCC_ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
IVCC_VOICE_WEBHOOK_SECRET=

# Stores. Empty REDIS_URL -> in-memory (single process only).
IVCC_DATABASE_URL=sqlite+aiosqlite:///./ivcc.db
IVCC_REDIS_URL=

# Mock tool behavior
IVCC_TOOL_FAILURE_RATE=0.0
IVCC_TOOL_MAX_RETRIES=3

# Static API key for /api endpoints. Empty disables the guard (demo).
IVCC_API_KEY=

# Demo login seeded into user_info at startup (frontend login dialog).
IVCC_DEMO_USER_ID=Bibek
IVCC_DEMO_USER_PASSWORD=Bibek
