# Copy to .env in this directory (next to docker-compose.yml) - docker compose
# reads it automatically. All keys empty = zero-key demo mode: the same agents,
# tools, handoffs and HITL run on a rule-based demo brain with no network calls.

# Inference via OpenRouter. Set a key to use real models.
IVCC_OPENROUTER_API_KEY=
IVCC_OPENROUTER_MODEL_TRIAGE=openai/gpt-4o-mini
IVCC_OPENROUTER_MODEL_SPECIALIST=openai/gpt-4o

# Voice via ElevenLabs (STT/TTS proxy + Conversational-AI custom-LLM webhook).
IVCC_ELEVENLABS_API_KEY=
IVCC_VOICE_WEBHOOK_SECRET=

# Mock tool behavior: raise to demo failure injection (e.g. 0.4).
IVCC_TOOL_FAILURE_RATE=0.0

# Postgres/Redis URLs are wired inside docker-compose.yml; for local
# no-docker development see backend/.env.example instead.
